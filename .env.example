# Copy to .env and fill in. Create an app password at:
# Bluesky -> Settings -> Privacy and Security -> App Passwords
BSKY_HANDLE=you.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Custom feed generator ---
# Public hostname your tunnel exposes (no scheme), e.g. abc.trycloudflare.com
FEEDGEN_HOSTNAME=
# Optional; defaults to did:web:<FEEDGEN_HOSTNAME>
# FEEDGEN_SERVICE_DID=
# Your account DID — set this after running publish_feed.py
FEEDGEN_PUBLISHER_DID=
# Optional overrides:
# JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe
# FEED_RKEY=discoursenuke
# FEED_DISPLAY_NAME=Mutuals minus US politics
# CLASSIFIER_THRESHOLD=0.08
# RETENTION_DAYS=3